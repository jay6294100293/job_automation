# .gitignore

# Environment variables
# ----------------------------------------------------------------
# Ignore the .env file to keep sensitive data like API keys and secret keys private.
.env

# Byte-compiled / optimized / DLL files
# ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# C extensions
# ----------------------------------------------------------------
*.so

# Distribution / packaging
# ----------------------------------------------------------------
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
# ----------------------------------------------------------------
*.manifest
*.spec

# Installer logs
# ----------------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
# ----------------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
# ----------------------------------------------------------------
*.mo
*.pot

# Django stuff:
# ----------------------------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Media files
# ----------------------------------------------------------------
/media/

# IDE / Editor specific
# ----------------------------------------------------------------
# PyCharm
.idea/
*.iws

# VSCode
.vscode/

# Virtual Environments
# ----------------------------------------------------------------
.venv/
venv/
ENV/
env/
virtualenv/
